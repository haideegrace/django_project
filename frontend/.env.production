# Frontend Production Environment Variables
# These are automatically used during npm run build

# API Server URL - Points to the same server's API (relative path works for same domain)
REACT_APP_API_URL=/api

# WebSocket Server URL - Dynamically constructed in webSocketService.js
# Will use wss:// on HTTPS, ws:// on HTTP (automatically detected)
REACT_APP_WS_URL=auto-detect

# App Environment
REACT_APP_ENV=production

# API Timeout (milliseconds)
REACT_APP_API_TIMEOUT=30000
