# Frontend Production Environment Variables
# These are automatically used during npm run build

# API Server URL - Points to the Render backend (cross-domain)
REACT_APP_API_URL=https://farm-backend-k98q.onrender.com/api

# WebSocket Server URL
REACT_APP_WS_URL=wss://farm-backend-k98q.onrender.com/ws

# App Environment
REACT_APP_ENV=production

# API Timeout (milliseconds)
REACT_APP_API_TIMEOUT=30000
